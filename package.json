{
	"name": "velo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"scrape": "tsx scripts/scrape.ts",
		"scrape:force": "tsx scripts/scrape.ts --force",
		"scrape:verbose": "tsx scripts/scrape.ts --force --verbose",
		"rollup": "tsx scripts/rollup.ts",
		"archive:cleanup": "tsx scripts/rollup.ts --cleanup-only",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:ingest": "tsx scripts/ingest.ts",
		"db:ingest:trending": "tsx scripts/ingest.ts --since=weekly --limit=25",
		"db:setup": "tsx scripts/migrate.ts && tsx scripts/ingest.ts --since=weekly --limit=25",
		"lint": "prettier --check . && eslint .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@rollup/rollup-linux-arm64-gnu": "^4.60.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/vite": "^4.0.9",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"eslint": "^9.0.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^16.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.20.1",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^4.0.9",
		"tsx": "^4.21.0",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.2.0"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@fontsource/space-grotesk": "^5.2.10",
		"@fontsource/space-mono": "^5.2.9",
		"@mendable/firecrawl-js": "^4.16.0",
		"better-sqlite3": "^12.8.0",
		"bits-ui": "^1.3.10",
		"cheerio": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"mode-watcher": "^0.5.1",
		"sharp": "^0.34.5",
		"svelte-icon": "^2.1.1",
		"svelte-sonner": "^0.3.28",
		"tailwind-merge": "^3.5.0"
	}
}
